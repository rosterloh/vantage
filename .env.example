# Copy to `.env` and fill in. `.env` is gitignored — never commit real credentials.
# The coordinator loads `.env` at startup (dotenvy); the real process environment
# still overrides anything set here.

# Listen address (optional; default 0.0.0.0:8080)
# VANTAGE_BIND=0.0.0.0:8080

# Log level (optional)
# RUST_LOG=info

# --- TURN (metered.ca account static credentials, or self-hosted coturn) ---
# Use ONE plain `turn:` URL (NOT `turns:` — TLS is not yet supported, see
# docs/turn-setup.md). Username/credential are the static pair from your metered
# dashboard, or the user you configured in coturn.
VANTAGE_TURN_URL=turn:standard.relay.metered.ca:443
VANTAGE_TURN_USER=your-metered-username
VANTAGE_TURN_PASS=your-metered-credential
